@using limbo.Models.ViewModels
@model UsersViewModel
@{ ViewData["Title"] = "Users"; }

@if (Model.StatusMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post" id="mainForm">
    <div class="d-flex gap-2 mb-3">
        <button type="submit"
                formaction="/users/block"
                class="btn btn-outline-danger toolbar-btn"
                disabled
                data-bs-toggle="tooltip"
                title="Block selected users">
            <i class="bi bi-lock-fill"></i> Block
        </button>
        <button type="submit"
                formaction="/users/unblock"
                class="btn btn-outline-success toolbar-btn"
                disabled
                data-bs-toggle="tooltip"
                title="Unblock selected users">
            <i class="bi bi-unlock-fill"></i>
        </button>
        <button type="submit"
                formaction="/users/delete"
                class="btn btn-outline-secondary toolbar-btn"
                disabled
                data-bs-toggle="tooltip"
                title="Delete selected users">
            <i class="bi bi-trash-fill"></i>
        </button>
        <button type="submit"
                formaction="/users/deleteunverified"
                class="btn btn-outline-warning toolbar-btn"
                disabled
                data-bs-toggle="tooltip"
                title="Delete unverified among selected">
            <i class="bi bi-person-x-fill"></i>
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 40px;" class="text-center">
                        <input type="checkbox" class="form-check-input" id="selectAll">
                    </th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Last Login</th>
                    <th>Registered</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="text-center">
                            <input type="checkbox"
                                   class="form-check-input row-checkbox"
                                   value="@user.Id">
                        </td>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>
                            @{
                                var badgeClass = user.Status switch
                                {
                                    "active"     => "bg-success",
                                    "blocked"    => "bg-danger",
                                    _            => "bg-warning text-dark"
                                };
                            }
                            <span class="badge @badgeClass">@user.Status</span>
                        </td>
                        <td>
                            @(user.LastLogin.HasValue
                                ? user.LastLogin.Value.ToString("yyyy-MM-dd HH:mm")
                                : "Never")
                        </td>
                        <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

@section Scripts {
<script>
    document.querySelectorAll('[data-bs-toggle="tooltip"]')
        .forEach(el => new bootstrap.Tooltip(el));

    const selectAll = document.getElementById('selectAll');
    const form      = document.getElementById('mainForm');

    function getSelectedIds() {
        return [...document.querySelectorAll('.row-checkbox:checked')]
            .map(cb => cb.value);
    }

    function getUniqIdValue() {
        return [...new Set(getSelectedIds())];
    }

    function updateToolbar() {
        const count = getSelectedIds().length;
        const total = document.querySelectorAll('.row-checkbox').length;

        document.querySelectorAll('.toolbar-btn').forEach(btn => btn.disabled = count === 0);

        selectAll.indeterminate = count > 0 && count < total;
        selectAll.checked       = count > 0 && count === total;
    }

    selectAll.addEventListener('change', function () {
        document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = this.checked);
        updateToolbar();
    });

    document.querySelectorAll('.row-checkbox').forEach(cb => cb.addEventListener('change', updateToolbar));

    form.addEventListener('submit', function () {
        form.querySelectorAll('.selected-id-input').forEach(el => el.remove());

        getUniqIdValue().forEach(id => {
            const input    = document.createElement('input');
            input.type     = 'hidden';
            input.name     = 'ids';
            input.value    = id;
            input.className = 'selected-id-input';
            form.appendChild(input);
        });
    });
</script>
}